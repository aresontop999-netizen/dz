# Token du bot Discord (Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=

# ID du salon Discord où tu postes tes créations (clic droit sur le salon > Copier l'ID)
SHOWCASE_CHANNEL_ID=

# ID du salon Discord où tu postes/gères tes formules de tarifs (optionnel,
# laisse vide si tu ne veux pas gérer les tarifs depuis Discord)
PRICING_CHANNEL_ID=

# URL et clé "service_role" de ton projet Supabase
# (Supabase > Project Settings > API)
# ⚠️ service_role = clé SECRÈTE, ne jamais la mettre dans le site, seulement dans le bot
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Emoji utilisé pour publier une création (mets une réaction avec cet emoji sur ton message)
PUBLISH_EMOJI=🚀

# Emoji utilisé pour dépublier / retirer une création du portfolio
REMOVE_EMOJI=🗑️
